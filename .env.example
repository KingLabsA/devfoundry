# --- Active model (set from the Models page) ---
LLM_PROVIDER=
LLM_MODEL=

# --- Rotation & MoE stage experts (Models page → Routing) ---
# Fallback chain tried on rate-limits/errors: "provider:model, provider:model"
LLM_ROTATION=
# Per-stage expert models (blank = active model)
LLM_MODEL_SPEC=
LLM_MODEL_CODEGEN=
LLM_MODEL_TASKS=
LLM_MODEL_REFINE=
# FreeLLMAPI self-hosted gateway (localhost:3002)
FREELLMAPI_KEY=

# --- LLM provider keys (fill in what you use; manage from the Models page) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
FIREWORKS_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=
DASHSCOPE_API_KEY=
NVIDIA_API_KEY=
SAMBANOVA_API_KEY=
GITHUB_TOKEN=
# Local runtimes (Ollama :11434, LM Studio :1234) need no keys.
# Custom / self-hosted OpenAI-compatible gateway (e.g. local proxy)
LLM_BASE_URL=
LLM_API_KEY=

# --- Framework endpoints (each runs as an isolated service) ---
METAGPT_URL=http://localhost:9101
BOLTDIY_URL=http://localhost:9102
OPENCODE_URL=http://localhost:9103
ORC_URL=http://localhost:9104
SUPERPOWERS_URL=http://localhost:9105

# --- Deployment ---
# auto | zip | docker | netlify | hf-spaces
DEPLOY_TARGET=auto
NETLIFY_AUTH_TOKEN=
HF_TOKEN=
VERCEL_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
SURGE_LOGIN=
SURGE_TOKEN=

# --- Backend ---
DEVFOUNDRY_HOST=0.0.0.0
DEVFOUNDRY_PORT=9100
DEVFOUNDRY_WORKSPACE=./workspace
DEVFOUNDRY_LOG_LEVEL=INFO
# Set to 1 for a scripted demo pipeline (no Docker services or API keys needed)
DEVFOUNDRY_MOCK=0
SERVICE_TIMEOUT_SECONDS=600
