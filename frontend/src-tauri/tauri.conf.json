{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevFoundry",
  "version": "0.2.5",
  "identifier": "com.devfoundry.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "KingLabs",
    "copyright": "\u00a9 2026 King3Djbl (KingLabs) \u2014 MIT license",
    "category": "DeveloperTool",
    "shortDescription": "The local-first AI software factory",
    "longDescription": "DevFoundry designs, codes, tests, and deploys applications on your own machine, with your own models. Created by King3Djbl of KingLabs, built with Claude Code. MIT licensed.",
    "homepage": "https://github.com/KingLabsA/devfoundry",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2NzgzNDU1ODMwMEJGNDUKUldSRnZ3Q0RWVFI0Tm1DTzM3Q0ZzYmdObHgyVmEyZGJOWUpPakFJbkRMem16T0ZMVHozSm03bUkK",
      "endpoints": [
        "https://github.com/KingLabsA/devfoundry/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "DevFoundry \u2014 Autonomous Software Factory",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:* https: wss:; img-src 'self' data: blob: https: http:; media-src 'self' data: blob: https: http:; font-src 'self' data: https:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline'; frame-src 'self' data: blob: https: http:"
    }
  }
}
