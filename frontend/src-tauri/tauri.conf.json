{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevFoundry",
  "version": "0.1.0",
  "identifier": "com.devfoundry.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      { "title": "DevFoundry — Autonomous Software Factory", "width": 1280, "height": 840 }
    ],
    "security": { "csp": "default-src 'self'; connect-src 'self' http://localhost:9100 ws://localhost:9100; style-src 'self' 'unsafe-inline'" }
  }
}
